# Change this to the production domain before indexing or building a sitemap.
PUBLIC_SITE_URL=https://www.wegoforklift.com

# Keep this false until real product copy, images, certifications, and policies are ready.
PUBLIC_ALLOW_INDEXING=false

# Optional lead routing for Netlify Functions.
# If empty, the lead endpoint runs in dry-run mode and returns JSON only.
LEAD_WEBHOOK_URL=
LEAD_EMAIL=sales@cnwegogroup.com
