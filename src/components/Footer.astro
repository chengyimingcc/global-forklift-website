---
import { Mail, MessageCircle, Phone } from "lucide-astro";
import type { Lang } from "@data/languages";
import { categories } from "@data/products";
import { servicePages, solutions } from "@data/content";
import { siteConfig } from "@data/site";
import { t } from "@data/i18n";
import { languagePath } from "@lib/seo";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-col">
      <h2>{siteConfig.brand}</h2>
      <p>{t(lang, "footerNote")}</p>
      <p>
        <Mail size={16} aria-hidden="true" /> {siteConfig.email}
      </p>
      <p>
        <Phone size={16} aria-hidden="true" /> {siteConfig.phone}
      </p>
      <p>
        <MessageCircle size={16} aria-hidden="true" /> WhatsApp {siteConfig.whatsapp}
      </p>
    </div>
    <div class="footer-grid">
      <div class="footer-col">
        <h3>{t(lang, "navProducts")}</h3>
        {categories.slice(0, 5).map((category) => <a href={languagePath(lang, `/products/${category.slug}/`)}>{category.label[lang]}</a>)}
      </div>
      <div class="footer-col">
        <h3>{t(lang, "navSolutions")}</h3>
        {solutions.slice(0, 4).map((solution) => <a href={languagePath(lang, `/solutions/${solution.slug}/`)}>{solution.title[lang]}</a>)}
      </div>
      <div class="footer-col">
        <h3>{t(lang, "navSupport")}</h3>
        {servicePages.slice(0, 3).map((page) => <a href={languagePath(lang, `/parts-service/${page.slug}/`)}>{page.title[lang]}</a>)}
        <a href={languagePath(lang, "/why-wego/")}>{t(lang, "navWhyWego")}</a>
        <a href={languagePath(lang, "/contact/")}>{t(lang, "navInquiry")}</a>
        <a href={languagePath(lang, "/privacy/")}>Privacy</a>
        <a href={languagePath(lang, "/terms/")}>Terms</a>
      </div>
    </div>
  </div>
  <div class="footer-bottom">
    <div class="container">© {new Date().getFullYear()} {siteConfig.legalName}. {siteConfig.address}</div>
  </div>
</footer>
