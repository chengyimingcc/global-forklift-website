---
import { MessageCircle, Send } from "lucide-astro";
import type { Lang } from "@data/languages";
import { siteConfig } from "@data/site";
import { t } from "@data/i18n";
import { languagePath } from "@lib/seo";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const whatsappNumber = siteConfig.whatsapp.replace(/\D/g, "");
const whatsappText = encodeURIComponent("Hello WEGO, I want to request a forklift quote.");
---

<aside class="inquiry-dock" aria-label="Quick inquiry methods">
  <a
    class="inquiry-dock-item"
    href={languagePath(lang, "/contact/")}
    aria-label={t(lang, "requestQuote")}
  >
    <span class="inquiry-dock-icon"><Send size={24} aria-hidden="true" /></span>
    <span class="inquiry-dock-label">
      <strong>{t(lang, "navInquiry")}</strong>
    </span>
  </a>
  <a
    class="inquiry-dock-item"
    href={`https://wa.me/${whatsappNumber}?text=${whatsappText}`}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Contact WEGO on WhatsApp"
  >
    <span class="inquiry-dock-icon"><MessageCircle size={24} aria-hidden="true" /></span>
    <span class="inquiry-dock-label">
      <strong>WhatsApp</strong>
    </span>
  </a>
</aside>
