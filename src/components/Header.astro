---
import { Menu, Send, X } from "lucide-astro";
import LanguageSwitcher from "@components/LanguageSwitcher.astro";
import type { Lang } from "@data/languages";
import { siteConfig } from "@data/site";
import { t } from "@data/i18n";
import { categories } from "@data/products";
import { solutions } from "@data/content";
import { languagePath } from "@lib/seo";

interface Props {
  lang: Lang;
  path: string;
}

const { lang } = Astro.props;
const pathname = Astro.url.pathname;
const pagePath = pathname.replace(new RegExp(`^/${lang}(?=/|$)`), "") || "/";
const navItems = [
  { label: t(lang, "navProducts"), href: languagePath(lang, "/products/"), match: `/${lang}/products/`, menu: "products" },
  { label: t(lang, "navSolutions"), href: languagePath(lang, "/solutions/"), match: `/${lang}/solutions/`, menu: "solutions" },
  { label: t(lang, "navService"), href: languagePath(lang, "/service/"), match: `/${lang}/service/` },
  { label: t(lang, "navNews"), href: languagePath(lang, "/news/"), match: `/${lang}/news/` },
  { label: t(lang, "navAboutUs"), href: languagePath(lang, "/about/"), match: `/${lang}/about/` },
  { label: t(lang, "navContactUs"), href: languagePath(lang, "/contact/"), match: `/${lang}/contact/` }
];
const menuCategories = categories;
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href={languagePath(lang, "/")} aria-label={siteConfig.brand}>
      <img class="brand-logo" src={siteConfig.logo} alt={siteConfig.brand} width="194" height="66" />
    </a>

    <nav class="nav" aria-label="Primary navigation">
      {
        navItems.map((item) => (
          <div class:list={["nav-item", item.menu && "has-mega"]}>
            <a href={item.href} aria-current={pathname.startsWith(item.match) ? "page" : undefined}>
              {item.label}
            </a>
            {
              item.menu === "products" && (
                <div class="mega-menu products-menu">
                  <div class="mega-feature">
                    <strong>{t(lang, "megaProductFinder")}</strong>
                    <span>{t(lang, "megaProductFinderBody")}</span>
                    <a href={languagePath(lang, "/products/")}>{t(lang, "megaViewAllProducts")}</a>
                  </div>
                  <div class="mega-grid">
                    {menuCategories.map((category) => (
                      <a class="mega-card" href={languagePath(lang, `/products/${category.slug}/`)}>
                        <img src={category.image} alt="" loading="lazy" width="96" height="64" />
                        <span>
                          <strong>{category.label[lang]}</strong>
                          <small>{category.capacityRange}</small>
                        </span>
                      </a>
                    ))}
                  </div>
                </div>
              )
            }
            {
              item.menu === "solutions" && (
                <div class="mega-menu list-menu">
                  <div class="mega-feature">
                    <strong>{t(lang, "navSolutions")}</strong>
                    <span>{t(lang, "megaSolutionsBody")}</span>
                  </div>
                  <div class="mega-list">
                    {solutions.map((solution) => <a href={languagePath(lang, `/solutions/${solution.slug}/`)}>{solution.title[lang]}</a>)}
                  </div>
                </div>
              )
            }
          </div>
        ))
      }
    </nav>

    <div class="header-actions">
      <LanguageSwitcher lang={lang} pagePath={pagePath} />
      <a class="btn primary" href={languagePath(lang, "/contact/")}>
        <Send size={17} aria-hidden="true" />
        <span>{t(lang, "navInquiry")}</span>
      </a>
    </div>

    <button class="btn secondary icon menu-toggle" type="button" aria-label="Open menu" aria-expanded="false">
      <Menu class="menu-open-icon" size={21} aria-hidden="true" />
      <X class="menu-close-icon" size={21} aria-hidden="true" style="display:none" />
    </button>
  </div>
  <nav class="mobile-nav" aria-label="Mobile navigation">
    {
      navItems.map((item) => (
        <a href={item.href} aria-current={pathname.startsWith(item.match) ? "page" : undefined}>
          {item.label}
        </a>
      ))
    }
    <a href={languagePath(lang, "/contact/")}>{t(lang, "navInquiry")}</a>
    <LanguageSwitcher lang={lang} pagePath={pagePath} mobile />
  </nav>
</header>

<script>
  const menuToggle = document.querySelector(".menu-toggle");
  const openIcon = document.querySelector(".menu-open-icon");
  const closeIcon = document.querySelector(".menu-close-icon");
  menuToggle?.addEventListener("click", () => {
    const open = document.body.classList.toggle("menu-open");
    menuToggle.setAttribute("aria-expanded", String(open));
    if (openIcon instanceof SVGElement && closeIcon instanceof SVGElement) {
      openIcon.style.display = open ? "none" : "block";
      closeIcon.style.display = open ? "block" : "none";
    }
  });

  document.querySelectorAll(".nav-item.has-mega").forEach((item) => {
    const open = () => item.classList.add("is-open");
    const close = () => item.classList.remove("is-open");
    const isRelatedTargetInside = (event: Event) => {
      const relatedTarget = event instanceof MouseEvent ? event.relatedTarget : null;
      return relatedTarget instanceof Node && item.contains(relatedTarget);
    };
    item.addEventListener("pointerenter", open);
    item.addEventListener("pointerleave", close);
    item.addEventListener("mouseenter", open);
    item.addEventListener("mouseleave", close);
    item.addEventListener("mouseover", open);
    item.addEventListener("mouseout", (event) => {
      if (!isRelatedTargetInside(event)) close();
    });
    item.addEventListener("focusin", open);
    item.addEventListener("focusout", () => {
      window.setTimeout(() => {
        if (!item.contains(document.activeElement)) close();
      }, 20);
    });
  });
</script>
