---
import type { Lang } from "@data/languages";
import type { Product } from "@data/products";
import { t } from "@data/i18n";

interface Props {
  product: Product;
  lang: Lang;
}

const { product, lang } = Astro.props;
const rows = product.specs.map((item) => [t(lang, item.labelKey), item.value[lang] ?? item.value.en]);
---

<table class="spec-table">
  <tbody>
    {rows.map(([label, value]) => <tr><th scope="row" dir="auto">{label}</th><td dir="auto">{value}</td></tr>)}
  </tbody>
</table>
