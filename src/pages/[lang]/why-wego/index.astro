---
import { CalendarDays, Factory, Globe2, Handshake, MapPin } from "lucide-astro";
import Layout from "@layouts/Layout.astro";
import { companyProfile } from "@data/company";
import { languages, type Lang } from "@data/languages";
import { siteConfig } from "@data/site";

export function getStaticPaths() {
  return languages.map((language) => ({ params: { lang: language.code } }));
}

const lang = Astro.params.lang as Lang;
const copy = companyProfile[lang] ?? companyProfile.en;
const isRtl = lang === "ar";

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "WEGO Group",
  brand: {
    "@type": "Brand",
    name: "WEGO"
  },
  url: siteConfig.baseUrl,
  logo: `${siteConfig.baseUrl}${siteConfig.logo}`,
  image: `${siteConfig.baseUrl}/images/company/wego-main-gate.png`,
  foundingDate: siteConfig.foundedYear,
  email: siteConfig.email,
  telephone: siteConfig.phone,
  description: copy.metaDescription,
  address: {
    "@type": "PostalAddress",
    streetAddress: "Industrial South Road",
    addressLocality: "Jinan",
    addressRegion: "Shandong",
    addressCountry: "CN"
  },
  areaServed: "Worldwide"
};

const stats = [
  { icon: CalendarDays, value: siteConfig.foundedYear, label: copy.founded },
  { icon: Handshake, value: "50+", label: copy.partners },
  { icon: Globe2, value: "120+", label: copy.markets },
  { icon: MapPin, value: "Jinan, China", label: copy.headquarters }
];

const photos = [
  { src: "/images/company/wego-main-gate.png", alt: copy.photoAlts[0] },
  { src: "/images/company/wego-factory-exterior.png", alt: copy.photoAlts[1] },
  { src: "/images/company/wego-production-line.png", alt: copy.photoAlts[2] }
];
---

<Layout
  lang={lang}
  title={copy.metaTitle}
  description={copy.metaDescription}
  path="/why-wego/"
  image="/images/company/global-market-network.avif"
  schema={organizationSchema}
>
  <main class="company-page">
    <header class="company-hero">
      <div class="container" dir={isRtl ? "rtl" : "ltr"}>
        <span class="company-label"><Factory size={17} aria-hidden="true" /> {copy.label}</span>
        <h1>{copy.title}</h1>
        <p>{copy.lead}</p>
      </div>
    </header>

    <section class="company-profile-section">
      <div class="container company-profile-layout">
        <article class="company-copy" dir={isRtl ? "rtl" : "ltr"}>
          <h2>{copy.profileTitle}</h2>
          {copy.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
        </article>

        <aside class="company-stats" aria-label={copy.label}>
          {stats.map(({ icon: Icon, value, label }) => (
            <div class="company-stat" dir={isRtl ? "rtl" : "ltr"}>
              <Icon size={22} stroke-width={1.8} aria-hidden="true" />
              <span>
                <strong dir="auto">{value}</strong>
                <small>{label}</small>
              </span>
            </div>
          ))}
        </aside>
      </div>
    </section>

    <section class="company-culture">
      <div class="container company-culture-inner" dir={isRtl ? "rtl" : "ltr"}>
        <span class="company-culture-mark" aria-hidden="true">“</span>
        <div>
          <h2>{copy.cultureTitle}</h2>
          <p>{copy.cultureBody}</p>
        </div>
      </div>
    </section>

    <section class="company-network-section">
      <div class="container" dir={isRtl ? "rtl" : "ltr"}>
        <span class="company-label"><Globe2 size={17} aria-hidden="true" /> {copy.networkLabel}</span>
        <div class="company-section-heading">
          <h2>{copy.networkTitle}</h2>
          <p>{copy.networkBody}</p>
        </div>
        <figure class="company-network-visual">
          <img
            src="/images/company/global-market-network.avif"
            alt={copy.networkTitle}
            width="1857"
            height="847"
            loading="lazy"
          />
        </figure>
      </div>
    </section>

    <section class="company-gallery-section">
      <div class="container" dir={isRtl ? "rtl" : "ltr"}>
        <span class="company-label"><Factory size={17} aria-hidden="true" /> {copy.galleryLabel}</span>
        <h2>{copy.galleryTitle}</h2>
        <div class="company-gallery">
          {photos.map((photo) => (
            <figure>
              <img src={photo.src} alt={photo.alt} width="360" height="240" loading="lazy" />
            </figure>
          ))}
        </div>
        <p class="company-welcome">{copy.welcome}</p>
      </div>
    </section>
  </main>
</Layout>

<style>
  .company-page {
    background: #fff;
    color: var(--ink);
  }

  .company-hero {
    border-bottom: 1px solid var(--line);
    background: #f5f8f3;
    padding: 72px 0 64px;
  }

  .company-label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--brand-dark);
    font-size: 0.82rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .company-hero h1 {
    max-width: 900px;
    margin: 16px 0 20px;
    font-size: 4.6rem;
    line-height: 0.96;
  }

  .company-hero p {
    max-width: 790px;
    margin: 0;
    color: var(--muted);
    font-size: 1.22rem;
  }

  .company-profile-section,
  .company-network-section,
  .company-gallery-section {
    padding: 84px 0;
  }

  .company-profile-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.65fr) minmax(280px, 0.8fr);
    gap: 88px;
    align-items: start;
  }

  .company-copy h2,
  .company-section-heading h2,
  .company-gallery-section h2,
  .company-culture h2 {
    margin: 0;
    font-size: 2.55rem;
    line-height: 1.08;
  }

  .company-copy p {
    margin: 24px 0 0;
    color: var(--muted);
    font-size: 1.04rem;
    line-height: 1.85;
  }

  .company-stats {
    border-top: 2px solid var(--brand);
  }

  .company-stat {
    display: grid;
    grid-template-columns: 32px minmax(0, 1fr);
    gap: 12px;
    align-items: center;
    border-bottom: 1px solid var(--line);
    padding: 21px 0;
  }

  .company-stat svg {
    color: var(--brand-dark);
  }

  .company-stat span {
    display: grid;
    gap: 2px;
  }

  .company-stat strong {
    font-size: 1.35rem;
    line-height: 1.1;
  }

  .company-stat small {
    color: var(--muted);
    font-size: 0.84rem;
  }

  .company-culture {
    border-block: 1px solid var(--line);
    background: #f5f8f3;
    padding: 62px 0;
  }

  .company-culture-inner {
    display: grid;
    grid-template-columns: 64px minmax(0, 860px);
    gap: 28px;
    align-items: start;
  }

  .company-culture-mark {
    color: var(--brand);
    font-family: Georgia, serif;
    font-size: 6rem;
    line-height: 0.8;
  }

  .company-culture p {
    margin: 18px 0 0;
    color: var(--muted);
    font-size: 1.12rem;
    line-height: 1.8;
  }

  .company-network-section {
    overflow: hidden;
  }

  .company-section-heading {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(300px, 0.75fr);
    gap: 70px;
    align-items: end;
    margin-top: 14px;
  }

  .company-section-heading p {
    margin: 0;
    color: var(--muted);
    line-height: 1.75;
  }

  .company-network-visual {
    margin: 42px 0 0;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 6px;
    background: #fff;
  }

  .company-network-visual img {
    display: block;
    width: 100%;
    aspect-ratio: 1857 / 847;
    object-fit: cover;
  }

  .company-gallery-section {
    border-top: 1px solid var(--line);
    background: #f8faf7;
  }

  .company-gallery-section h2 {
    margin-top: 14px;
  }

  .company-gallery {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
    margin-top: 38px;
  }

  .company-gallery figure {
    margin: 0;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 6px;
    background: #fff;
  }

  .company-gallery img {
    display: block;
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    transition: transform 320ms ease;
  }

  .company-gallery figure:hover img {
    transform: scale(1.035);
  }

  .company-welcome {
    max-width: 880px;
    margin: 44px 0 0;
    border-inline-start: 4px solid var(--brand);
    padding-inline-start: 22px;
    color: var(--ink);
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.55;
  }

  @media (max-width: 900px) {
    .company-hero h1 {
      font-size: 3.5rem;
    }

    .company-profile-layout,
    .company-section-heading {
      grid-template-columns: 1fr;
      gap: 44px;
    }

    .company-gallery {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .company-gallery figure:last-child {
      grid-column: 1 / -1;
    }

    .company-gallery figure:last-child img {
      aspect-ratio: 2 / 1;
    }
  }

  @media (max-width: 640px) {
    .company-hero {
      padding: 52px 0 46px;
    }

    .company-hero h1 {
      font-size: 2.8rem;
    }

    .company-hero p {
      font-size: 1.05rem;
    }

    .company-profile-section,
    .company-network-section,
    .company-gallery-section {
      padding: 58px 0;
    }

    .company-copy h2,
    .company-section-heading h2,
    .company-gallery-section h2,
    .company-culture h2 {
      font-size: 2.05rem;
    }

    .company-culture-inner {
      grid-template-columns: 1fr;
      gap: 6px;
    }

    .company-culture-mark {
      font-size: 4.5rem;
    }

    .company-gallery {
      grid-template-columns: 1fr;
    }

    .company-gallery figure:last-child {
      grid-column: auto;
    }

    .company-gallery figure:last-child img {
      aspect-ratio: 3 / 2;
    }

    .company-welcome {
      font-size: 1.08rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .company-gallery img {
      transition: none;
    }
  }
</style>
