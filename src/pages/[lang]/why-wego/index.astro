---
import { languages, type Lang } from "@data/languages";
import { languagePath } from "@lib/seo";

export function getStaticPaths() {
  return languages.map((language) => ({ params: { lang: language.code } }));
}

const lang = Astro.params.lang as Lang;
return Astro.redirect(languagePath(lang, "/about/"), 301);
---
