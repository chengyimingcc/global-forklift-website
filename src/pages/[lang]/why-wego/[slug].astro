---
import { CheckCircle2, Factory } from "lucide-astro";
import Layout from "@layouts/Layout.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import LeadForm from "@components/LeadForm.astro";
import { languages, type Lang } from "@data/languages";
import { companyPages, getCompanyPage } from "@data/content";
import { t } from "@data/i18n";
import { languagePath } from "@lib/seo";
import { breadcrumbSchema } from "@lib/schema";

export function getStaticPaths() {
  return languages.flatMap((language) => companyPages.map((page) => ({ params: { lang: language.code, slug: page.slug } })));
}

const lang = Astro.params.lang as Lang;
const page = getCompanyPage(Astro.params.slug ?? "");
if (!page) {
  return Astro.redirect(languagePath(lang, "/why-wego/"));
}
const pagePath = `/why-wego/${page.slug}/`;
const breadcrumbs = [
  { name: t(lang, "breadcrumbHome"), url: languagePath(lang, "/") },
  { name: "Why WEGO", url: languagePath(lang, "/why-wego/") },
  { name: page.title[lang], url: languagePath(lang, pagePath) }
];
---

<Layout lang={lang} title={`${page.title[lang]} | Why WEGO Forklift`} description={page.summary[lang]} path={pagePath} image={page.image} schema={breadcrumbSchema(breadcrumbs)}>
  <main>
    <header class="page-header">
      <div class="container">
        <Breadcrumbs items={[
          { label: t(lang, "breadcrumbHome"), href: languagePath(lang, "/") },
          { label: "Why WEGO", href: languagePath(lang, "/why-wego/") },
          { label: page.title[lang] }
        ]} />
        <span class="section-label"><Factory size={17} aria-hidden="true" /> Why WEGO</span>
        <h1 class="section-title">{page.title[lang]}</h1>
        <p class="lead">{page.summary[lang]}</p>
      </div>
    </header>
    <section class="section">
      <div class="container split">
        <article class="prose">
          {page.image && <div class="product-media"><img src={page.image} alt={page.title[lang]} width="1280" height="720" /></div>}
          <h2>Proof points</h2>
          <ul class="check-list">
            {page.bullets.map((item) => <li><CheckCircle2 size={18} aria-hidden="true" /> <span>{item}</span></li>)}
          </ul>
          <h2>Content to finalize</h2>
          <p>Replace this section with exact company evidence, certificates, photos, case materials, and export records before enabling indexing.</p>
        </article>
        <LeadForm lang={lang} />
      </div>
    </section>
  </main>
</Layout>
