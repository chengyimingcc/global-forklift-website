---
import { languages } from "@data/languages";

export function getStaticPaths() {
  const legacySlugs = ["company", "global-network", "certificates", "case-studies"];
  return languages.flatMap((language) =>
    legacySlugs.map((slug) => ({ params: { lang: language.code, slug } }))
  );
}

return Astro.redirect(`/${Astro.params.lang}/about/`, 301);
---
