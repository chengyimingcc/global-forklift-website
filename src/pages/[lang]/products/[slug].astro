---
import { CheckCircle2, Download, PackageCheck } from "lucide-astro";
import Layout from "@layouts/Layout.astro";
import LeadForm from "@components/LeadForm.astro";
import ProductCard from "@components/ProductCard.astro";
import SpecTable from "@components/SpecTable.astro";
import { languages, type Lang } from "@data/languages";
import { categories, getCategory, getCategoryProducts, getProduct, getProductName, products } from "@data/products";
import { t } from "@data/i18n";
import { languagePath } from "@lib/seo";
import { breadcrumbSchema, productSchema } from "@lib/schema";

export function getStaticPaths() {
  return languages.flatMap((language) => [
    ...products.map((product) => ({ params: { lang: language.code, slug: product.slug } })),
    ...categories.map((category) => ({ params: { lang: language.code, slug: category.slug } }))
  ]);
}

const lang = Astro.params.lang as Lang;
const slug = Astro.params.slug ?? "";
const product = getProduct(slug);
const category = getCategory(slug);

if (!product && !category) {
  return Astro.redirect(languagePath(lang, "/products/"));
}

const pagePath = `/products/${slug}/`;
const pageTitle = product ? product.translations[lang].seoTitle : `${category!.label[lang]} | WEGO Forklift Products`;
const pageDescription = product
  ? product.translations[lang].seoDescription
  : `${category!.summary[lang]} Compare WEGO catalog models and request an export quote.`;
const pageImage = product ? product.image : category!.image;
const breadcrumbs = product
  ? [
      { name: t(lang, "breadcrumbHome"), url: languagePath(lang, "/") },
      { name: t(lang, "allProducts"), url: languagePath(lang, "/products/") },
      { name: getProductName(product, lang), url: languagePath(lang, pagePath) }
    ]
  : [
      { name: t(lang, "breadcrumbHome"), url: languagePath(lang, "/") },
      { name: t(lang, "allProducts"), url: languagePath(lang, "/products/") },
      { name: category!.label[lang], url: languagePath(lang, pagePath) }
    ];
const categoryProducts = category ? getCategoryProducts(category.slug) : [];
const productCategory = product ? getCategory(product.category) : undefined;
const related = product ? products.filter((item) => item.category === product.category && item.slug !== product.slug).slice(0, 3) : [];
const categoryApplicationCopy: Record<string, Array<{ title: string; description: string }>> = {
  "lithium-electric-forklifts": [
    {
      title: "Indoor warehouse operations",
      description: "Battery power supports low-noise, zero local exhaust operation around racking, packing, and finished goods areas."
    },
    {
      title: "Food and pharmaceutical storage",
      description: "A cleaner powertrain is suited to controlled warehouses, cold-chain staging, and facilities with strict indoor air requirements."
    },
    {
      title: "Production line supply",
      description: "Responsive electric drive helps move components and finished products through frequent, repeatable factory handling cycles."
    }
  ],
  "diesel-forklifts": [
    {
      title: "Outdoor loading yards",
      description: "Diesel power is suitable for continuous trailer loading, unloading, and cargo transfer in open industrial yards."
    },
    {
      title: "Factory and building materials",
      description: "Multiple capacity and mast options support machinery, pallets, construction materials, and general industrial loads."
    },
    {
      title: "Mixed-surface logistics",
      description: "Pneumatic tire options and strong gradeability suit routes that move between warehouses, docks, and outdoor storage."
    }
  ],
  "heavy-duty-forklifts": [
    {
      title: "Ports and terminals",
      description: "High-capacity models support heavy cargo transfer, terminal yards, container-related work, and long outdoor duty cycles."
    },
    {
      title: "Steel and metal handling",
      description: "Robust chassis and large load centers are suited to coils, billets, fabricated structures, and dense industrial cargo."
    },
    {
      title: "Heavy manufacturing",
      description: "Seven to ten ton capacity supports machinery installation, plant logistics, molds, and oversized production materials."
    }
  ],
  "rough-terrain-forklifts": [
    {
      title: "Construction sites",
      description: "Higher ground clearance and outdoor tires help move blocks, timber, tools, and palletized materials across uneven sites."
    },
    {
      title: "Agriculture and forestry",
      description: "The 3.5T platform supports farm supplies, timber, feed, and seasonal cargo on unpaved working surfaces."
    },
    {
      title: "Remote outdoor yards",
      description: "A simple diesel configuration suits material handling where paved floors and indoor charging infrastructure are unavailable."
    }
  ],
  "electric-pallet-stackers": [
    {
      title: "Narrow aisle stacking",
      description: "The compact chassis supports pallet placement and retrieval where a counterbalance forklift would require too much space."
    },
    {
      title: "Retail and distribution storage",
      description: "Quiet battery operation is suitable for stock rooms, distribution centers, and frequent indoor replenishment tasks."
    },
    {
      title: "Short-distance pallet movement",
      description: "Walk-behind controls provide an efficient option for moving and lifting pallets between receiving, storage, and dispatch zones."
    }
  ]
};
const categoryApplications = category ? categoryApplicationCopy[category.slug] ?? [] : [];
const collectionSchema = category
  ? {
      "@context": "https://schema.org",
      "@type": "CollectionPage",
      name: category.label[lang],
      description: category.summary[lang],
      hasPart: categoryProducts.map((item) => ({
        "@type": "Product",
        name: getProductName(item, lang),
        url: languagePath(lang, `/products/${item.slug}/`)
      }))
    }
  : undefined;
const schema = product ? [productSchema(product, lang), breadcrumbSchema(breadcrumbs)] : [collectionSchema, breadcrumbSchema(breadcrumbs)];
---

<Layout lang={lang} title={pageTitle} description={pageDescription} path={pagePath} image={pageImage} type={product ? "product" : "website"} schema={schema}>
  <main>
    {
      category && (
        <>
          <section class="product-hero category-hero">
            <div class="container">
              <div class="split category-hero-grid">
                <div>
                  <span class="section-label"><PackageCheck size={17} aria-hidden="true" /> Product Line</span>
                  <h1 class="section-title">{category.label[lang]}</h1>
                  <p class="lead">{category.summary[lang]}</p>
                  <div class="meta-row">
                    <span class="pill">{category.capacityRange}</span>
                    {category.powerTypes.map((type) => <span class="pill">{type}</span>)}
                    <span class="pill">{t(lang, "currentProductRange")}</span>
                  </div>
                </div>
                <div class="product-media">
                  <img src={category.image} alt={category.label[lang]} width="1280" height="720" />
                </div>
              </div>
            </div>
          </section>

          <section id="models" class="section category-models">
            <div class="container">
              <h2 class="section-title">{categoryProducts.length ? "Catalog models" : "Model pages reserved"}</h2>
              <div class="grid three">
                {categoryProducts.length ? categoryProducts.map((item) => <ProductCard product={item} lang={lang} />) : (
                  <article class="card">
                    <div class="card-body">
                      <h3>Future model range</h3>
                      <p>Add exact WEGO models, images, specifications, and brochure downloads here when available.</p>
                    </div>
                  </article>
                )}
              </div>
            </div>
          </section>

          <section class="section soft category-applications">
            <div class="container">
              <h2 class="section-title">{t(lang, "recommendedApplications")}</h2>
              <div class="category-application-grid">
                {categoryApplications.map((application) => (
                  <article class="category-application-card">
                    <h3>{application.title}</h3>
                    <p>{application.description}</p>
                  </article>
                ))}
              </div>
            </div>
          </section>
        </>
      )
    }

    {
      product && (
        <>
          <section class="product-hero">
            <div class="container">
              <div class="split">
                <div>
                  <div class="meta-row">
                    {productCategory && <span class="pill">{productCategory.label[lang]}</span>}
                    <span class="pill">{product.brand}</span>
                    <span class="pill">{product.sku}</span>
                    <span class="pill">{product.capacityTons}</span>
                  </div>
                  <h1 class="section-title">{getProductName(product, lang)}</h1>
                  <p class="lead">{product.translations[lang].shortDescription}</p>
                  {product.brochure && (
                    <div class="button-row" style="margin-top: 22px;">
                      <a class="btn secondary" href={product.brochure}><Download size={17} aria-hidden="true" /> {t(lang, "downloadSpec")}</a>
                    </div>
                  )}
                </div>
                <div class="product-gallery" data-product-gallery>
                  <div class="product-media product-gallery-stage">
                    <img
                      src={product.image}
                      alt={getProductName(product, lang)}
                      width="1400"
                      height="1400"
                      fetchpriority="high"
                      data-gallery-main
                    />
                  </div>
                  <div class="product-gallery-thumbs" aria-label={`${getProductName(product, lang)} image gallery`}>
                    {
                      product.gallery.map((image, index) => (
                        <button
                          class="product-gallery-thumb"
                          type="button"
                          aria-label={`View image ${index + 1} of ${product.gallery.length}`}
                          aria-current={index === 0 ? "true" : "false"}
                          data-gallery-src={image}
                        >
                          <img src={image} alt="" loading="lazy" width="180" height="180" />
                        </button>
                      ))
                    }
                  </div>
                </div>
              </div>
            </div>
          </section>

          <section class="section">
            <div class="container split">
              <div>
                <h2>{t(lang, "productSpecs")}</h2>
                <SpecTable product={product} lang={lang} />
                <h2>{t(lang, "highlights")}</h2>
                <ul class="check-list">
                  {product.translations[lang].highlights.map((item) => <li><CheckCircle2 size={18} aria-hidden="true" /> <span>{item}</span></li>)}
                </ul>
                <h2>{t(lang, "applications")}</h2>
                <ul class="check-list">
                  {product.translations[lang].applications.map((item) => <li><CheckCircle2 size={18} aria-hidden="true" /> <span>{item}</span></li>)}
                </ul>
              </div>
              <aside id="inquiry">
                <LeadForm lang={lang} defaultProduct={product.slug} />
              </aside>
            </div>
          </section>

          {related.length > 0 && (
            <section class="section soft">
              <div class="container">
                <h2 class="section-title">{t(lang, "relatedProducts")}</h2>
                <div class="grid three">
                  {related.map((item) => <ProductCard product={item} lang={lang} />)}
                </div>
              </div>
            </section>
          )}
        </>
      )
    }
  </main>

  <script>
    document.querySelectorAll("[data-product-gallery]").forEach((gallery) => {
      const mainImage = gallery.querySelector("[data-gallery-main]");
      const thumbnails = gallery.querySelectorAll("[data-gallery-src]");
      thumbnails.forEach((thumbnail) => {
        thumbnail.addEventListener("click", () => {
          if (!(mainImage instanceof HTMLImageElement) || !(thumbnail instanceof HTMLButtonElement)) return;
          const nextImage = thumbnail.dataset.gallerySrc;
          if (!nextImage) return;
          mainImage.src = nextImage;
          thumbnails.forEach((item) => item.setAttribute("aria-current", String(item === thumbnail)));
        });
      });
    });
  </script>
</Layout>
