---
import { PackageCheck, Search } from "lucide-astro";
import Layout from "@layouts/Layout.astro";
import ProductCard from "@components/ProductCard.astro";
import { languages, type Lang } from "@data/languages";
import { categories, products } from "@data/products";
import { t } from "@data/i18n";

export function getStaticPaths() {
  return languages.map((language) => ({ params: { lang: language.code } }));
}

const lang = Astro.params.lang as Lang;
---

<Layout
  lang={lang}
  title={`${t(lang, "productCenterTitle")} | WEGO`}
  description={t(lang, "productCenterLead")}
  path="/products/"
>
  <main>
    <header class="page-header catalog-header">
      <div class="container">
        <span class="section-label"><PackageCheck size={17} aria-hidden="true" /> {t(lang, "productCenter")}</span>
        <h1 class="section-title">{t(lang, "productCenterTitle")}</h1>
        <p class="lead">{t(lang, "productCenterLead")}</p>
        <div class="field product-search">
          <label for="product-search"><Search size={16} aria-hidden="true" /> {t(lang, "searchCatalog")}</label>
          <input id="product-search" type="search" placeholder={t(lang, "searchPlaceholder")} />
        </div>
        <div class="filters" aria-label="Product filters">
          <button class="filter-btn" type="button" data-filter="all" aria-pressed="true">{t(lang, "allProducts")}</button>
          {categories.map((category) => <button class="filter-btn" type="button" data-filter={category.slug} aria-pressed="false">{category.label[lang]}</button>)}
        </div>
      </div>
    </header>

    <section class="section soft">
      <div class="container">
        <span class="section-label">{t(lang, "catalogModels")}</span>
        <div class="grid three product-grid">
          {products.map((product) => <ProductCard product={product} lang={lang} />)}
        </div>
      </div>
    </section>
  </main>
</Layout>

<script>
  const filterButtons = document.querySelectorAll("[data-filter]");
  const searchInput = document.querySelector("#product-search");
  const cards = document.querySelectorAll(".product-card");
  let activeFilter = "all";

  function applyFilters() {
    const query = searchInput instanceof HTMLInputElement ? searchInput.value.trim().toLowerCase() : "";
    cards.forEach((card) => {
      if (!(card instanceof HTMLElement)) return;
      const categoryMatch = activeFilter === "all" || card.dataset.category === activeFilter;
      const text = `${card.dataset.name || ""} ${card.textContent || ""}`.toLowerCase();
      const queryMatch = !query || text.includes(query);
      card.style.display = categoryMatch && queryMatch ? "" : "none";
    });
  }

  filterButtons.forEach((button) => {
    button.addEventListener("click", () => {
      if (!(button instanceof HTMLButtonElement)) return;
      activeFilter = button.dataset.filter || "all";
      filterButtons.forEach((item) => item.setAttribute("aria-pressed", String(item === button)));
      applyFilters();
    });
  });
  searchInput?.addEventListener("input", applyFilters);
</script>
