---
import Layout from "@layouts/Layout.astro";
import LeadForm from "@components/LeadForm.astro";
import { languages, type Lang } from "@data/languages";
import { siteConfig } from "@data/site";
import { t } from "@data/i18n";

export function getStaticPaths() {
  return languages.map((language) => ({ params: { lang: language.code } }));
}

const lang = Astro.params.lang as Lang;
---

<Layout lang={lang} title={`${t(lang, "navAbout")} | ${siteConfig.brand}`} description={t(lang, "aboutIntro")} path="/about/">
  <main>
    <header class="page-header">
      <div class="container">
        <span class="eyebrow">{t(lang, "navAbout")}</span>
        <h1 class="section-title">{t(lang, "navAbout")}</h1>
        <p class="lead">{t(lang, "aboutIntro")}</p>
      </div>
    </header>
    <section class="section">
      <div class="container split">
        <article class="prose">
          <h2>Factory profile</h2>
          <p>Replace this section with production lines, inspection capability, export markets, and warehouse photos.</p>
          <h2>Certifications</h2>
          <p>Add CE, ISO, EPA, battery certificates, or local compliance documents that are actually available.</p>
          <h2>Export proof</h2>
          <p>Add customer countries, shipping cases, container loading photos, and warranty procedures.</p>
        </article>
        <LeadForm lang={lang} />
      </div>
    </section>
  </main>
</Layout>
