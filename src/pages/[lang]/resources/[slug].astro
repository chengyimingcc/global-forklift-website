---
import { languages, type Lang } from "@data/languages";
import { resources } from "@data/content";
import { languagePath } from "@lib/seo";

export function getStaticPaths() {
  return languages.flatMap((language) => resources.map((resource) => ({ params: { lang: language.code, slug: resource.slug } })));
}

const lang = Astro.params.lang as Lang;
return Astro.redirect(languagePath(lang, "/news/"), 301);
---
