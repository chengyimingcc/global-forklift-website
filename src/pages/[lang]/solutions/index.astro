---
import { ArrowRight, Boxes } from "lucide-astro";
import Layout from "@layouts/Layout.astro";
import { languages, type Lang } from "@data/languages";
import { solutions } from "@data/content";
import { solutionUi } from "@data/solutions-ui";
import { languagePath } from "@lib/seo";

export function getStaticPaths() {
  return languages.map((language) => ({ params: { lang: language.code } }));
}

const lang = Astro.params.lang as Lang;
---

<Layout lang={lang} title={`${solutionUi.indexTitle[lang]} | WEGO Forklift`} description={solutionUi.indexIntro[lang]} path="/solutions/">
  <main class="solutions-page">
    <header class="solution-index-hero">
      <div class="container">
        <span class="company-label"><Boxes size={18} aria-hidden="true" /> {solutionUi.label[lang]}</span>
        <h1>{solutionUi.indexTitle[lang]}</h1>
        <p>{solutionUi.indexIntro[lang]}</p>
      </div>
    </header>

    <section class="solution-index-grid section">
      <div class="container solution-directory">
        {solutions.map((solution, index) => (
          <a class="solution-directory-item" href={languagePath(lang, `/solutions/${solution.slug}/`)}>
            <figure><img src={solution.image} alt={solution.title[lang]} width="900" height="620" loading={index < 3 ? "eager" : "lazy"} /></figure>
            <div>
              <span>{String(index + 1).padStart(2, "0")}</span>
              <h2>{solution.title[lang]}</h2>
              <p>{solution.summary[lang]}</p>
              <strong>{solutionUi.explore[lang]} <ArrowRight size={17} aria-hidden="true" /></strong>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="solution-contact-band">
      <div class="container"><div><h2>{solutionUi.contactTitle[lang]}</h2><p>{solutionUi.contactBody[lang]}</p></div><a class="btn primary" href={languagePath(lang, "/contact/")}>{solutionUi.contactTitle[lang]} <ArrowRight size={17} aria-hidden="true" /></a></div>
    </section>
  </main>
</Layout>
