---
import Layout from "@layouts/Layout.astro";
import { languages, type Lang } from "@data/languages";
import { siteConfig } from "@data/site";
import { legalContent } from "@data/legal";

export function getStaticPaths() {
  return languages.map((language) => ({ params: { lang: language.code } }));
}

const lang = Astro.params.lang as Lang;
const document = legalContent[lang].privacy;
const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: document.title,
  description: document.description,
  url: `${siteConfig.baseUrl}/${lang}/privacy/`,
  dateModified: "2026-07-16",
  isPartOf: { "@type": "WebSite", name: siteConfig.brand, url: siteConfig.baseUrl }
};
---

<Layout lang={lang} title={`${document.title} | ${siteConfig.brand}`} description={document.description} path="/privacy/" schema={schema}>
  <main>
    <header class="page-header">
      <div class="container">
        <p class="eyebrow">{siteConfig.brand}</p>
        <h1 class="section-title">{document.title}</h1>
        <p class="lead">{document.intro}</p>
        <p class="legal-updated">{document.updatedLabel}: <time datetime="2026-07-16">{document.updatedDate}</time></p>
      </div>
    </header>
    <section class="section legal-section">
      <div class="container legal-layout">
        <nav class="legal-toc" aria-label={document.contentsLabel}>
          <strong>{document.contentsLabel}</strong>
          <ol>
            {document.sections.map((section) => <li><a href={`#${section.id}`}>{section.title.replace(/^\d+\.\s*/, "")}</a></li>)}
          </ol>
        </nav>
        <article class="prose legal-prose">
          {document.sections.map((section) => (
            <section id={section.id}>
              <h2>{section.title}</h2>
              <p>{section.body}</p>
            </section>
          ))}
        </article>
      </div>
    </section>
  </main>
</Layout>
