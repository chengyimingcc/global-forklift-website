---
import { getCollection } from "astro:content";
import { ArrowRight, Newspaper, ShieldCheck } from "lucide-astro";
import Layout from "@layouts/Layout.astro";
import LeadForm from "@components/LeadForm.astro";
import ProductCard from "@components/ProductCard.astro";
import { languages, type Lang } from "@data/languages";
import { heroSlides, homeCounters } from "@data/marketing";
import { categories, products } from "@data/products";
import { siteConfig } from "@data/site";
import { solutions } from "@data/content";
import { languagePath } from "@lib/seo";
import { organizationSchema, websiteSchema } from "@lib/seo";

export async function getStaticPaths() {
  return languages.map((language) => ({ params: { lang: language.code } }));
}

const lang = Astro.params.lang as Lang;
const latestNews = (await getCollection("news"))
  .sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime())
  .slice(0, 3);

const featureProducts = products.slice(0, 6);
const schema = [organizationSchema(), websiteSchema(lang)];
---

<Layout
  lang={lang}
  title={`${siteConfig.brand} | ${heroSlides[0].title[lang]}`}
  description={heroSlides[0].body[lang]}
  path="/"
  image={heroSlides[0].image}
  schema={schema}
>
  <main>
    <section class="hero wego-home-hero" data-home-hero>
      <div class="hero-slider" aria-hidden="true">
        {
          heroSlides.map((slide, index) => (
            <figure class:list={["hero-slide", index === 0 && "is-active"]} data-slide>
              <img
                src={slide.image}
                alt={slide.alt[lang]}
                width="2279"
                height="1280"
                loading={index === 0 ? "eager" : "lazy"}
                fetchpriority={index === 0 ? "high" : undefined}
              />
            </figure>
          ))
        }
      </div>
      <div class="container hero-content">
        <div class="hero-copy">
          <p class="eyebrow">{siteConfig.brand}</p>
          <h1 class="headline" data-hero-title>{heroSlides[0].title[lang]}</h1>
          <p class="lead" data-hero-body>{heroSlides[0].body[lang]}</p>
          <div class="hero-actions">
            <a class="btn primary" href={languagePath(lang, heroSlides[0].href)}>Explore products</a>
            <a class="btn secondary" href={languagePath(lang, "/contact/")}>Send inquiry</a>
          </div>
        </div>
      </div>
      <script is:inline type="application/json" data-home-hero-slides set:html={JSON.stringify(heroSlides.map((slide) => ({ title: slide.title[lang], body: slide.body[lang] })))} />
    </section>

    <section class="section">
      <div class="container">
        <div class="section-heading">
          <span class="section-label">Products</span>
          <h2 class="section-title">Current forklift families</h2>
          <p class="section-intro">The product center stays organized around real export inquiry paths rather than retail pricing pages.</p>
        </div>
        <div class="product-family-grid">
          {
            categories.map((category) => (
              <a class="family-card" href={languagePath(lang, `/products/${category.slug}/`)}>
                <img src={category.image} alt={category.label[lang]} width="320" height="220" loading="lazy" />
                <div>
                  <strong>{category.label[lang]}</strong>
                  <span>{category.summary[lang]}</span>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section soft">
      <div class="container">
        <div class="section-heading">
          <span class="section-label"><ShieldCheck size={16} aria-hidden="true" /> Solutions</span>
          <h2 class="section-title">Solutions by working scene</h2>
          <p class="section-intro">Each route starts from the buyer's operating condition and ends with a narrower WEGO model recommendation.</p>
        </div>
        <div class="solution-grid">
          {
            solutions.map((solution) => (
              <article class="card solution-card">
                <a class="card-media" href={languagePath(lang, `/solutions/${solution.slug}/`)}>
                  <img src={solution.image} alt={solution.title[lang]} width="1280" height="720" loading="lazy" />
                </a>
                <div class="card-body">
                  <h3><a href={languagePath(lang, `/solutions/${solution.slug}/`)}>{solution.title[lang]}</a></h3>
                  <p>{solution.summary[lang]}</p>
                  <a class="inline-link" href={languagePath(lang, `/solutions/${solution.slug}/`)}>
                    View solution <ArrowRight size={16} aria-hidden="true" />
                  </a>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section soft">
      <div class="container">
        <div class="section-heading">
          <span class="section-label"><Newspaper size={16} aria-hidden="true" /> News</span>
          <h2 class="section-title">Latest updates and technical articles</h2>
          <p class="section-intro">The news area is set up for ongoing article publishing through the admin workspace.</p>
        </div>
        <div class="grid three">
          {
            latestNews.map((article) => (
              <article class="card news-card">
                <a class="card-media" href={languagePath(lang, `/news/${article.data.permalink}/`)}>
                  <img src={article.data.cover} alt={article.data.title[lang]} width="1280" height="720" loading="lazy" />
                </a>
                <div class="card-body">
                  <p class="card-meta">{article.data.publishedAt.toISOString().slice(0, 10)}</p>
                  <h3><a href={languagePath(lang, `/news/${article.data.permalink}/`)}>{article.data.title[lang]}</a></h3>
                  <p>{article.data.excerpt[lang]}</p>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section soft">
      <div class="container">
        <div class="section-heading">
          <span class="section-label">Featured models</span>
          <h2 class="section-title">Current inquiry-ready models</h2>
          <p class="section-intro">Pricing is not published. Each product page is structured for specification review and direct quotation requests.</p>
        </div>
        <div class="grid three">
          {featureProducts.map((product) => <ProductCard product={product} lang={lang} />)}
        </div>
      </div>
    </section>

    <section class="section home-contact-band">
      <div class="container split">
        <div>
          <span class="section-label">Contact Us</span>
          <h2 class="section-title">Leave a message</h2>
          <p class="section-intro">Use the form as the main conversion point for organic search traffic and direct overseas inquiries.</p>
          <div class="contact-direct">
            <p><strong>Email</strong> {siteConfig.email}</p>
            <p><strong>Phone / WhatsApp</strong> {siteConfig.phone}</p>
            <p><strong>Address</strong> {siteConfig.address}</p>
          </div>
        </div>
        <LeadForm lang={lang} inquiryType="homepage" />
      </div>
      <div class="container counter-band" data-counter-band>
        {
          homeCounters.map((counter) => (
            <article class="counter-card">
              <strong data-count={counter.value} data-suffix={counter.suffix ?? ""} aria-label={`${counter.value}${counter.suffix ?? ""}`}>0</strong>
              <span>{counter.label[lang]}</span>
            </article>
          ))
        }
      </div>
    </section>
  </main>

  <script is:inline>
    document.querySelectorAll("[data-home-hero]").forEach((hero) => {
      const slides = Array.from(hero.querySelectorAll("[data-slide]"));
      const dataNode = hero.querySelector("[data-home-hero-slides]");
      const title = hero.querySelector("[data-hero-title]");
      const body = hero.querySelector("[data-hero-body]");
      if (!(dataNode instanceof HTMLScriptElement) || !title || !body || slides.length < 2) return;
      const content = JSON.parse(dataNode.textContent || "[]");
      let index = 0;
      window.setInterval(() => {
        index = (index + 1) % slides.length;
        slides.forEach((slide, slideIndex) => slide.classList.toggle("is-active", slideIndex === index));
        title.textContent = content[index]?.title || "";
        body.textContent = content[index]?.body || "";
      }, 4800);
    });

    const counterBand = document.querySelector("[data-counter-band]");
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    function buildRollingNumber(node) {
      const target = node.getAttribute("data-count") || "0";
      const suffix = node.getAttribute("data-suffix") || "";
      if (reduceMotion) {
        node.textContent = `${target}${suffix}`;
        return;
      }

      node.textContent = "";
      [...target].forEach((character, digitIndex) => {
        const finalDigit = Number(character);
        const digit = document.createElement("span");
        digit.className = "counter-digit";
        digit.setAttribute("aria-hidden", "true");
        const track = document.createElement("span");
        track.className = "counter-digit-track";
        const sequence = [...Array(10).keys(), ...Array(10).keys(), ...Array(finalDigit + 1).keys()];
        sequence.forEach((value) => {
          const item = document.createElement("span");
          item.textContent = String(value);
          track.append(item);
        });
        track.style.setProperty("--counter-stop", String(sequence.length - 1));
        track.style.setProperty("--counter-delay", `${digitIndex * 90}ms`);
        digit.append(track);
        node.append(digit);
      });
      if (suffix) {
        const suffixNode = document.createElement("span");
        suffixNode.className = "counter-suffix";
        suffixNode.textContent = suffix;
        node.append(suffixNode);
      }
      requestAnimationFrame(() => requestAnimationFrame(() => node.classList.add("is-rolling")));
    }

    if (counterBand) {
      const startCounters = () => counterBand.querySelectorAll("[data-count]").forEach(buildRollingNumber);
      if (reduceMotion || !("IntersectionObserver" in window)) {
        startCounters();
      } else {
        const observer = new IntersectionObserver((entries) => {
          if (!entries.some((entry) => entry.isIntersecting)) return;
          startCounters();
          observer.disconnect();
        }, { threshold: 0.35 });
        observer.observe(counterBand);
      }
    }
  </script>
</Layout>
