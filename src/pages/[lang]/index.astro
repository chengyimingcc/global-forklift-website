---
import { ArrowRight, CheckCircle2, Factory, PackageCheck, Search, Send, ShieldCheck, Wrench } from "lucide-astro";
import Layout from "@layouts/Layout.astro";
import LeadForm from "@components/LeadForm.astro";
import ProductCard from "@components/ProductCard.astro";
import { languages, type Lang } from "@data/languages";
import { t } from "@data/i18n";
import { categories, products } from "@data/products";
import { servicePages, solutions } from "@data/content";
import { companyProfile } from "@data/company";
import { primaryMarkets, siteConfig } from "@data/site";
import { languagePath, organizationSchema, websiteSchema } from "@lib/seo";

export function getStaticPaths() {
  return languages.map((language) => ({ params: { lang: language.code } }));
}

const lang = Astro.params.lang as Lang;
const schema = [organizationSchema(), websiteSchema(lang)];
const catalogCategories = categories.filter((category) => category.status === "catalog");
const featuredProducts = [products[2], products[4], products[5], products[8], products[11], products[14]];
const localizedHeroTitle = t(lang, "heroTitle");
const localizedHeroBody = t(lang, "heroBody");
const profileCopy = companyProfile[lang] ?? companyProfile.en;
const heroSlides = [
  {
    image: "/images/products/heavy-duty-100t/01.webp",
    title: localizedHeroTitle,
    body: localizedHeroBody
  },
  {
    image: "/images/products/lithium-25t/01.webp",
    title: localizedHeroTitle,
    body: localizedHeroBody
  },
  {
    image: "/images/products/rough-terrain-35t/01.webp",
    title: localizedHeroTitle,
    body: localizedHeroBody
  },
  {
    image: "/images/products/diesel-50t-3-stage/01.webp",
    title: localizedHeroTitle,
    body: localizedHeroBody
  }
];
const mosaicTiles = [
  { image: "/images/products/lithium-30t/01.webp", label: categories[0].label[lang], detail: "2.5T-3.5T" },
  { image: "/images/products/diesel-35t-2-stage/01.webp", label: categories[1].label[lang], detail: "2.5T-5.0T" },
  { image: "/images/products/rough-terrain-35t/01.webp", label: categories[3].label[lang], detail: "3.5T" },
  { image: "/images/products/electric-pallet-stacker/01.webp", label: categories[4].label[lang], detail: "MC12" }
];
---

<Layout
  lang={lang}
  title={t(lang, "seoHomeTitle")}
  description={t(lang, "seoHomeDescription")}
  path="/"
  image={siteConfig.defaultImage}
  schema={schema}
>
  <main>
    <section class="hero wego-hero" data-hero-slider>
      <div class="hero-slider" aria-hidden="true">
        {
          heroSlides.map((slide, index) => (
            <div class:list={["hero-slide", index === 0 && "is-active"]} data-slide>
              <img
                src={slide.image}
                alt=""
                width="1280"
                height="720"
                loading={index === 0 ? "eager" : "lazy"}
                decoding="async"
                fetchpriority={index === 0 ? "high" : "low"}
              />
            </div>
          ))
        }
      </div>
      <div class="hero-content">
        <h1 class="headline" data-hero-title>{heroSlides[0].title}</h1>
        <p class="lead" data-hero-body>{heroSlides[0].body}</p>
        <div class="hero-panel" aria-label="WEGO catalog readiness">
          <div class="hero-stat"><strong>{catalogCategories.length}</strong><span>{t(lang, "homeCatalogLines")}</span></div>
          <div class="hero-stat"><strong>{products.length}</strong><span>{t(lang, "homeModelPages")}</span></div>
          <div class="hero-stat"><strong>{primaryMarkets.length}</strong><span>{t(lang, "homeExportRegions")}</span></div>
        </div>
      </div>
      <script is:inline type="application/json" data-hero-slides set:html={JSON.stringify(heroSlides)} />
    </section>

    <section class="section mosaic-section" data-mosaic>
      <div class="container mosaic-layout">
        <div class="mosaic-copy">
          <span class="section-label"><Factory size={17} aria-hidden="true" /> {t(lang, "productCategories")}</span>
          <h2 class="section-title">{t(lang, "heroTitle")}</h2>
          <p class="section-intro">{t(lang, "heroBody")}</p>
          <a class="btn primary" href={languagePath(lang, "/contact/")}>
            <Send size={17} aria-hidden="true" />
            <span>{t(lang, "heroSecondary")}</span>
          </a>
        </div>
        <div class="mosaic-wall" aria-label="WEGO forklift product visual wall">
          {
            mosaicTiles.map((tile, index) => (
              <article class:list={["mosaic-tile", `tile-${index + 1}`]}>
                <img src={tile.image} alt={`${tile.label} ${tile.detail}`} loading="lazy" width="900" height="620" />
                <span>
                  <strong>{tile.label}</strong>
                  <small>{tile.detail}</small>
                </span>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section id="product-finder" class="section dark-band">
      <div class="container">
        <span class="section-label"><Search size={17} aria-hidden="true" /> {t(lang, "megaProductFinder")}</span>
        <h2 class="section-title">{t(lang, "compareSpecs")}</h2>
        <p class="section-intro">{t(lang, "megaProductFinderBody")}</p>
        <div class="finder-panel">
          <a class="finder-cell finder-lead" href={languagePath(lang, "/products/")}>
            <strong>{t(lang, "allProducts")}</strong>
            <span>{t(lang, "megaViewAllProducts")}</span>
          </a>
          <a class="finder-cell" href={languagePath(lang, "/products/lithium-electric-forklifts/")}><strong>{categories[0].label[lang]}</strong><span>{categories[0].capacityRange}</span></a>
          <a class="finder-cell" href={languagePath(lang, "/products/diesel-forklifts/")}><strong>{categories[1].label[lang]}</strong><span>{categories[1].capacityRange}</span></a>
          <a class="finder-cell" href={languagePath(lang, "/products/heavy-duty-forklifts/")}><strong>{categories[2].label[lang]}</strong><span>{categories[2].capacityRange}</span></a>
          <a class="finder-cell" href={languagePath(lang, "/products/electric-pallet-stackers/")}><strong>{categories[4].label[lang]}</strong><span>HELI MC12</span></a>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <span class="section-label"><PackageCheck size={17} aria-hidden="true" /> {t(lang, "navProducts")}</span>
        <h2 class="section-title">{t(lang, "productCategories")}</h2>
        <p class="section-intro">{t(lang, "heroBody")}</p>
        <div class="grid three">
          {
            categories.map((category) => (
              <article class="card category-card">
                <a class="card-media" href={languagePath(lang, `/products/${category.slug}/`)}>
                  <img src={category.image} alt={category.label[lang]} loading="lazy" width="1280" height="720" />
                </a>
                <div class="card-body">
                  <div class="meta-row">
                    <span class="pill">{category.capacityRange}</span>
                    <span class="pill">{t(lang, "currentProductRange")}</span>
                  </div>
                  <h3><a href={languagePath(lang, `/products/${category.slug}/`)}>{category.label[lang]}</a></h3>
                  <p>{category.summary[lang]}</p>
                  <a class="btn secondary" href={languagePath(lang, `/products/${category.slug}/`)}>{t(lang, "viewDetails")}</a>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section soft">
      <div class="container">
        <span class="section-label"><Factory size={17} aria-hidden="true" /> {t(lang, "featuredProducts")}</span>
        <h2 class="section-title">{t(lang, "catalogModels")}</h2>
        <div class="grid three">
          {featuredProducts.map((product) => <ProductCard product={product} lang={lang} />)}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <span class="section-label"><ShieldCheck size={17} aria-hidden="true" /> {t(lang, "navSolutions")}</span>
        <h2 class="section-title">{t(lang, "industriesTitle")}</h2>
        <p class="section-intro">{t(lang, "megaSolutionsBody")}</p>
        <div class="grid three">
          {
            solutions.map((solution) => (
              <article class="card solution-card">
                <a class="card-media" href={languagePath(lang, `/solutions/${solution.slug}/`)}>
                  <img src={solution.image} alt={solution.title[lang]} loading="lazy" width="1280" height="720" />
                </a>
                <div class="card-body">
                  <h3>{solution.title[lang]}</h3>
                  <p>{solution.summary[lang]}</p>
                  <ul class="mini-list">
                    {solution.needs.slice(0, 2).map((need) => <li><CheckCircle2 size={15} aria-hidden="true" /> {need}</li>)}
                  </ul>
                  <a class="btn secondary" href={languagePath(lang, `/solutions/${solution.slug}/`)}>{t(lang, "readMore")}</a>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section dark-band">
      <div class="container split">
        <div>
          <span class="section-label"><Wrench size={17} aria-hidden="true" /> {t(lang, "navSupport")}</span>
          <h2 class="section-title">{t(lang, "servicesTitle")}</h2>
          <p class="section-intro">{t(lang, "megaSupportBody")}</p>
          <div class="grid two">
            {
              servicePages.map((page) => (
                <a class="service-link" href={languagePath(lang, `/parts-service/${page.slug}/`)}>
                  <strong>{page.title[lang]}</strong>
                  <span>{page.summary[lang]}</span>
                </a>
              ))
            }
          </div>
        </div>
        <LeadForm lang={lang} />
      </div>
    </section>

    <section class="company-home-band">
      <div class="container" dir={lang === "ar" ? "rtl" : "ltr"}>
        <span class="section-label"><Factory size={17} aria-hidden="true" /> {profileCopy.label}</span>
        <h2 class="section-title">{profileCopy.networkTitle}</h2>
        <p class="section-intro">{profileCopy.lead}</p>
        <a class="btn primary" href={languagePath(lang, "/why-wego/")}>
          {t(lang, "navWhyWego")} <ArrowRight size={17} aria-hidden="true" />
        </a>
      </div>
    </section>

  </main>

  <script>
    document.querySelectorAll("[data-hero-slider]").forEach((slider) => {
      const slidesDataNode = slider.querySelector("[data-hero-slides]");
      const slidesData = slidesDataNode?.textContent ? JSON.parse(slidesDataNode.textContent) : [];
      const slides = Array.from(slider.querySelectorAll("[data-slide]"));
      const title = slider.querySelector("[data-hero-title]");
      const body = slider.querySelector("[data-hero-body]");
      let active = 0;
      let timer = 0;

      const setActive = (next: number) => {
        active = (next + slides.length) % slides.length;
        slides.forEach((slide, index) => slide.classList.toggle("is-active", index === active));
        const slideData = slidesData[active];
        if (!slideData) return;
        if (title) title.textContent = slideData.title;
        if (body) body.textContent = slideData.body;
      };

      const start = () => {
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
        window.clearInterval(timer);
        timer = window.setInterval(() => setActive(active + 1), 5200);
      };

      start();
    });

    const mosaic = document.querySelector("[data-mosaic]");
    if (mosaic && "IntersectionObserver" in window) {
      const observer = new IntersectionObserver(
        ([entry]) => {
          if (entry.isIntersecting) mosaic.classList.add("is-visible");
        },
        { threshold: 0.25 }
      );
      observer.observe(mosaic);
    } else {
      mosaic?.classList.add("is-visible");
    }
  </script>
</Layout>
