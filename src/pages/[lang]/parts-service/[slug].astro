---
import { languages, type Lang } from "@data/languages";
import { servicePages } from "@data/content";
import { languagePath } from "@lib/seo";

export function getStaticPaths() {
  return languages.flatMap((language) => servicePages.map((page) => ({ params: { lang: language.code, slug: page.slug } })));
}

const lang = Astro.params.lang as Lang;
return Astro.redirect(languagePath(lang, "/service/"), 301);
---
