---
import Layout from "@layouts/Layout.astro";
import { siteConfig } from "@data/site";
---

<Layout lang="en" title={`Page not found | ${siteConfig.brand}`} description="The requested page was not found." path="/404/" noindex={true}>
  <main>
    <section class="page-header">
      <div class="container">
        <h1 class="section-title">Page not found</h1>
        <p class="lead">The page may have moved. Return to the product catalog.</p>
        <a class="btn primary" href="/en/products/">Products</a>
      </div>
    </section>
  </main>
</Layout>
